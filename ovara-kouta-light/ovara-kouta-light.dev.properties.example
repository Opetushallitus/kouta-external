ovara-kouta-light.s3.transferFileBucket = S3-BUCKETIN NIMI
ovara-kouta-light.s3.transferFileTargetRoleArn = arn:aws:iam::XXXXXXXXXXXX:role/ROLE-NAME
ovara-kouta-light.s3.transferFileSaveRetryCount = 3
ovara-kouta-light.s3.transferFileMaxItemCount = 1000

ovara-kouta-light.db.url=jdbc:postgresql://localhost:5435/koutaexternal
ovara-kouta-light.db.user=oph
ovara-kouta-light.db.password=oph
ovara-kouta-light.db.maxConnections=50
ovara-kouta-light.db.minConnections=10
ovara-kouta-light.db.registerMbeans=true
